                    <td><?= $i;?></td>
                    <td><?= $model->date_constribution;?></td>
                    <td><?= $model->month_payment;?></td>
                    <td><?= $debt;?></td>
                    <td><?= $sum;?></td>
                </tr>
        <?php
                $dateAt = strtotime('+1 MONTH', strtotime( $model->date_constribution));

                $model->date_constribution = date('Y-m-d', $dateAt);

            }
        ?>

        </tbody>
    </table>

